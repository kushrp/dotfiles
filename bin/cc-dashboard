#!/usr/bin/env bash
# cc-dashboard — central control board for all tmux sessions / parallel agents.
# One fuzzy screen: every agent pane across every session, tagged with its Claude
# state (⏸ waiting / 🤖 working / ✅ done — from cc-status.sh) and, for blocked
# agents, how long they've been waiting. Ordering, top to bottom:
#   1. waiting — LONGEST wait first (the one starving for your attention)
#   2. working
#   3. done
#   4. idle / non-agent panes
# Live preview of the pane + git status, and action keys. Bound to `prefix a`
# (tmux popup) and `ccd` in the shell.
#
#   enter  jump        ctrl-x  kill        ctrl-g  lazygit
#   ctrl-n new agent (type a name first)   ctrl-r  refresh
set -o pipefail

_glyph() { case "$1" in waiting) printf '⏸';; working) printf '🤖';; done) printf '✅';; *) printf '·';; esac; }
# ANSI color per state (fzf --ansi): waiting amber, working cyan, done green.
_color() { case "$1" in waiting) printf '\e[1;33m';; working) printf '\e[36m';; done) printf '\e[32m';; *) printf '\e[2m';; esac; }
# rank so waiting(0) < working(1) < done(2) < idle(3)
_rank()  { case "$1" in waiting) printf 0;; working) printf 1;; done) printf 2;; *) printf 3;; esac; }
# seconds → compact age (90s → 1m, 3700s → 1h)
_fmt() { local s=$1; if (( s >= 3600 )); then printf '%dh' $((s/3600)); elif (( s >= 60 )); then printf '%dm' $((s/60)); else printf '%ds' "$s"; fi; }

_rows() {
  # rank \t secondary \t target \t display   — agent PANES only, sorted by rank
  # then secondary. Secondary for waiting rows is the wait-start epoch so the
  # OLDEST wait floats to the very top; other states get a large constant.
  # Pane-scoped because agents commonly run as split panes in one window.
  local target st name cmd path title since now dur secs secondary disp row agents="" all=""
  now=$(date +%s)
  while IFS=$'\t' read -r target st name cmd path title since; do
    dur=""; secondary=9999999999
    if [[ "$st" == waiting && "$since" =~ ^[0-9]+$ ]]; then
      secs=$(( now - since )); (( secs < 0 )) && secs=0
      dur=" $(_fmt "$secs")"
      secondary=$since                       # older (smaller) sorts first
    fi
    disp=$(printf '%b%s%s\e[0m  %s  \e[2m‹%s›\e[0m' \
      "$(_color "$st")" "$(_glyph "$st")" "$dur" "$name" "${title:-$cmd}")
    row=$(printf '%s\t%s\t%s\t%s' "$(_rank "$st")" "$secondary" "$target" "$disp")
    all+="$row"$'\n'
    if [[ "$st" != none || "$cmd" == claude || "$cmd" == node || "$cmd" == [0-9]*.[0-9]* || "$path" == *"/.claude/worktrees/"* ]]; then
      agents+="$row"$'\n'
    fi
  done < <(tmux list-panes -a \
      -F '#{session_name}:#{window_index}.#{pane_index}	#{?#{@cc_status},#{@cc_status},none}	#{session_name}:#{window_index}.#{pane_index}	#{pane_current_command}	#{pane_current_path}	#{pane_title}	#{@cc_waiting_since}' 2>/dev/null)
  printf '%s' "${agents:-$all}" | sort -t$'\t' -k1,1n -k2,2n
}

_preview() {
  local target="$1"
  local path; path=$(tmux display-message -p -t "$target" '#{pane_current_path}' 2>/dev/null)
  local st;   st=$(tmux show-options -pqv -t "$target" @cc_status 2>/dev/null)
  local since; since=$(tmux show-options -pqv -t "$target" @cc_waiting_since 2>/dev/null)
  local age=""
  [[ "$st" == waiting && "$since" =~ ^[0-9]+$ ]] && age=" for $(_fmt $(( $(date +%s) - since )))"
  printf '\e[1;34m%s\e[0m   \e[33m%s\e[0m\n' "${path/#$HOME/~}" "${st:+[$st$age]}"
  if git -C "$path" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    printf '\e[36m %s\e[0m\n' "$(git -C "$path" symbolic-ref --quiet --short HEAD 2>/dev/null || echo detached)"
    git -C "$path" -c color.status=always status -s 2>/dev/null | head -12
  fi
  printf '\e[2m── live output ─────────────────────────\e[0m\n'
  tmux capture-pane -ep -t "$target" 2>/dev/null | sed '/^[[:space:]]*$/d' | tail -40
}

case "$1" in
  --rows)    _rows; exit 0 ;;
  --preview) _preview "$2"; exit 0 ;;
esac

if [[ -z "$(_rows)" ]]; then
  echo "No agents yet. Start one with:  cc <name>   (or run claude in a pane)"; sleep 1.6; exit 0
fi

# enter jumps to the exact pane, across any window/session: select the pane +
# window, then point the client at its session. When launched from a tmux
# keybinding/popup, $1 is the invoking client — a popup runs in its own throwaway
# client, so we must retarget THAT one with -c, else the jump lands nowhere.
client="$1"
if [[ -n "$client" ]]; then
  jump="tmux select-pane -t {3} 2>/dev/null; tmux select-window -t {3} 2>/dev/null; tmux switch-client -c '$client' -t {3}"
else
  jump="tmux select-pane -t {3} 2>/dev/null; tmux select-window -t {3} 2>/dev/null; tmux switch-client -t {3} 2>/dev/null || tmux attach -t {3}"
fi

# ctrl-x kills just that PANE, never the whole window — sibling agents share it.
# ctrl-n spawns a fresh `cc`-style agent window.
# --height=100% so fzf fills the whole popup; otherwise it inherits --height=40%
# from FZF_DEFAULT_OPTS and leaves the bottom of the popup blank.
_rows | fzf --ansi --no-sort --height=100% --delimiter='\t' --with-nth=4.. \
  --border-label ' 🤖 agents — longest wait on top · enter:jump  ^x:kill  ^g:lazygit  ^n:new  ^r:refresh ' \
  --preview-window 'right:60%,border-left' \
  --preview "$0 --preview {3}" \
  --bind "ctrl-r:reload($0 --rows)" \
  --bind "ctrl-x:execute-silent(tmux kill-pane -t {3})+reload($0 --rows)" \
  --bind "ctrl-g:execute(p=\$(tmux display-message -p -t {3} '#{pane_current_path}'); tmux display-popup -E -d \"\$p\" -w 90% -h 90% lazygit)" \
  --bind "ctrl-n:execute(name={q}; [ -n \"\$name\" ] && tmux new-window -n \"\$name\" \"claude --worktree '\$name' --dangerously-skip-permissions\")+abort" \
  --bind "enter:become($jump)"
