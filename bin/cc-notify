#!/usr/bin/env bash
# cc-notify — channel-pluggable notification dispatcher for the agent fleet.
# Called by cc-status.sh (Claude hooks) when an agent changes state. Fans out to:
#   - macOS desktop (terminal-notifier), always, for every notified state
#   - phone/remote channels (ntfy, Slack), per CC_NOTIFY_PHONE_STATES
# Every remote message carries the agent's tmux target (session:win.pane) so a
# future reply-listener can route a response back with `tmux send-keys`.
#
# Config (secrets stay OUT of git): sourced from ~/.config/cc-notify/config —
#   NTFY_URL="https://ntfy.sh/<your-private-topic>"
#   SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."
#   CC_NOTIFY_PHONE_STATES="waiting"   # space-separated: which states reach the phone
#   CC_NOTIFY_DESKTOP=1                 # 0 to silence desktop
#   CC_NOTIFY_THROTTLE=45              # seconds; suppress duplicate phone pings per pane+state
# Anything unset falls back to a sensible default; missing channels are skipped.
# Fail-open: never exit non-zero, never block the hook.
set -o pipefail

CFG="${CC_NOTIFY_CONFIG:-$HOME/.config/cc-notify/config}"
# shellcheck disable=SC1090
[ -r "$CFG" ] && . "$CFG"

state="" title="Claude" message="" pane="" target="" age="" proj=""
while [ $# -gt 0 ]; do
  case "$1" in
    --state)   state="$2"; shift 2 ;;
    --title)   title="$2"; shift 2 ;;
    --message) message="$2"; shift 2 ;;
    --pane)    pane="$2"; shift 2 ;;     # tmux pane id, e.g. %42
    --proj)    proj="$2"; shift 2 ;;
    --age)     age="$2"; shift 2 ;;
    *) shift ;;
  esac
done

: "${CC_NOTIFY_DESKTOP:=1}"
: "${CC_NOTIFY_PHONE_STATES:=waiting}"
: "${CC_NOTIFY_THROTTLE:=45}"

# Resolve a human target (session:win.pane) from the pane id, for reply routing.
if [ -n "$pane" ] && command -v tmux >/dev/null 2>&1; then
  target=$(tmux display-message -p -t "$pane" '#{session_name}:#{window_index}.#{pane_index}' 2>/dev/null)
fi
[ -n "$target" ] || target="$proj"

# --- desktop (always, cheap) ------------------------------------------------
if [ "$CC_NOTIFY_DESKTOP" = "1" ] && command -v terminal-notifier >/dev/null 2>&1; then
  terminal-notifier -title "$title" -subtitle "$target" -message "$message" \
    -sound Glass -group "cc-$proj" >/dev/null 2>&1 &
fi

# --- should this state reach the phone? -------------------------------------
phone=0
for s in $CC_NOTIFY_PHONE_STATES; do [ "$s" = "$state" ] && phone=1; done
[ "$phone" = 1 ] || exit 0

# --- per-pane+state throttle so toggling agents don't spam the lock screen ---
tdir="${TMPDIR:-/tmp}/cc-notify"; mkdir -p "$tdir" 2>/dev/null
key=$(printf '%s-%s' "${pane:-x}" "$state" | tr -c 'A-Za-z0-9_-' '_')
tf="$tdir/$key.last"
now=$(date +%s)
if [ -r "$tf" ]; then
  last=$(cat "$tf" 2>/dev/null || echo 0)
  [ $(( now - last )) -lt "$CC_NOTIFY_THROTTLE" ] && exit 0
fi
echo "$now" > "$tf" 2>/dev/null

body="$message"
[ -n "$age" ] && body="$body (waiting ${age})"
body="$body
agent: $target"

# --- ntfy (push; "waiting" pushes carry reply buttons for two-way control) ---
# Reply buttons POST a "cmd|pane" message to the control topic; cc-notify-listen
# (a launchd daemon) consumes it and runs tmux send-keys on that pane.
if [ -n "${NTFY_URL:-}" ] && command -v jq >/dev/null 2>&1; then
  ntfy_base="${NTFY_URL%/*}"; ntfy_topic="${NTFY_URL##*/}"
  : "${NTFY_CONTROL_URL:=${NTFY_URL}-ctrl}"
  case "$state" in
    waiting) prio=4; tags='["warning","inbox_tray"]' ;;
    done)    prio=3; tags='["white_check_mark"]' ;;
    *)       prio=3; tags='["robot_face"]' ;;
  esac
  actions='[]'
  if [ "$state" = waiting ] && [ -n "$pane" ]; then
    actions=$(jq -nc --arg u "$NTFY_CONTROL_URL" --arg p "$pane" '
      [ {action:"http",label:"Proceed", url:$u,method:"POST",body:("proceed|"  + $p),clear:true},
        {action:"http",label:"Continue",url:$u,method:"POST",body:("continue|" + $p),clear:true},
        {action:"http",label:"Stop",    url:$u,method:"POST",body:("stop|"     + $p),clear:true} ]')
  fi
  payload=$(jq -nc --arg topic "$ntfy_topic" --arg title "$title · $target" \
    --arg msg "$body" --argjson prio "$prio" --argjson tags "$tags" --argjson actions "$actions" \
    '{topic:$topic,title:$title,message:$msg,priority:$prio,tags:$tags}
     + (if ($actions|length)>0 then {actions:$actions} else {} end)')
  curl -fsS --max-time 6 -d "$payload" "$ntfy_base" >/dev/null 2>&1 &
fi

# --- Slack (incoming webhook; push-only) ------------------------------------
if [ -n "${SLACK_WEBHOOK_URL:-}" ]; then
  case "$state" in
    waiting) emoji=":hourglass_flowing_sand:" ;;
    done)    emoji=":white_check_mark:" ;;
    *)       emoji=":robot_face:" ;;
  esac
  text="$emoji *$title* — $message  \`$target\`"
  [ -n "$age" ] && text="$text  _(waiting ${age})_"
  payload=$(printf '{"text":%s}' "$(printf '%s' "$text" | sed 's/\\/\\\\/g; s/"/\\"/g' | awk '{printf "\"%s\"", $0}')")
  curl -fsS --max-time 6 -X POST -H 'Content-type: application/json' \
    --data "$payload" "$SLACK_WEBHOOK_URL" >/dev/null 2>&1 &
fi

exit 0
