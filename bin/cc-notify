#!/usr/bin/env bash
# cc-notify — notification dispatcher for the agent fleet. Called by cc-status.sh
# (Claude hooks) when an agent changes state. Fans out to:
#   - macOS desktop (terminal-notifier), always, for every notified state
#   - Slack and/or Discord webhooks, for states in CC_NOTIFY_REMOTE_STATES
# Each remote message names the agent's tmux target (session:win.pane).
#
# Config (secrets stay OUT of git): sourced from ~/.config/cc-notify/config —
#   SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."
#   DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/..."
#   CC_NOTIFY_REMOTE_STATES="waiting"  # space-separated: which states go remote
#   CC_NOTIFY_DESKTOP=1                 # 0 to silence desktop
#   CC_NOTIFY_THROTTLE=45              # seconds; suppress dup pings per pane+state
# Anything unset falls back to a default; missing channels are skipped.
# Fail-open: never exit non-zero, never block the hook.
set -o pipefail

CFG="${CC_NOTIFY_CONFIG:-$HOME/.config/cc-notify/config}"
# shellcheck disable=SC1090
[ -r "$CFG" ] && . "$CFG"

state="" title="Claude" message="" pane="" target="" age="" proj=""
while [ $# -gt 0 ]; do
  case "$1" in
    --state)   state="$2"; shift 2 ;;
    --title)   title="$2"; shift 2 ;;
    --message) message="$2"; shift 2 ;;
    --pane)    pane="$2"; shift 2 ;;
    --proj)    proj="$2"; shift 2 ;;
    --age)     age="$2"; shift 2 ;;
    *) shift ;;
  esac
done

: "${CC_NOTIFY_DESKTOP:=1}"
: "${CC_NOTIFY_REMOTE_STATES:=${CC_NOTIFY_PHONE_STATES:-waiting}}"  # legacy name honored
: "${CC_NOTIFY_THROTTLE:=45}"

# Human target (session:win.pane) from the pane id, so a message says which agent.
if [ -n "$pane" ] && command -v tmux >/dev/null 2>&1; then
  target=$(tmux display-message -p -t "$pane" '#{session_name}:#{window_index}.#{pane_index}' 2>/dev/null)
fi
[ -n "$target" ] || target="$proj"

# --- desktop (always, cheap) ------------------------------------------------
if [ "$CC_NOTIFY_DESKTOP" = "1" ] && command -v terminal-notifier >/dev/null 2>&1; then
  terminal-notifier -title "$title" -subtitle "$target" -message "$message" \
    -sound Glass -group "cc-$proj" >/dev/null 2>&1 &
fi

# --- does this state go to the remote channels? -----------------------------
remote=0
for s in $CC_NOTIFY_REMOTE_STATES; do [ "$s" = "$state" ] && remote=1; done
[ "$remote" = 1 ] || exit 0

# --- per-pane+state throttle so toggling agents don't spam the channels ------
tdir="${TMPDIR:-/tmp}/cc-notify"; mkdir -p "$tdir" 2>/dev/null
key=$(printf '%s-%s' "${pane:-x}" "$state" | tr -c 'A-Za-z0-9_-' '_')
tf="$tdir/$key.last"
now=$(date +%s)
if [ -r "$tf" ]; then
  last=$(cat "$tf" 2>/dev/null || echo 0)
  [ $(( now - last )) -lt "$CC_NOTIFY_THROTTLE" ] && exit 0
fi
echo "$now" > "$tf" 2>/dev/null

case "$state" in
  waiting) emoji=":hourglass_flowing_sand:"; demoji="⏳" ;;
  done)    emoji=":white_check_mark:";       demoji="✅" ;;
  *)       emoji=":robot_face:";             demoji="🤖" ;;
esac
suffix=""; [ -n "$age" ] && suffix=" (waiting ${age})"

# --- Slack (incoming webhook) -----------------------------------------------
if [ -n "${SLACK_WEBHOOK_URL:-}" ] && command -v jq >/dev/null 2>&1; then
  text="$emoji *${title}* — ${message} \`${target}\`${suffix}"
  jq -nc --arg t "$text" '{text:$t}' \
    | curl -fsS --max-time 6 -H 'Content-type: application/json' --data @- \
        "$SLACK_WEBHOOK_URL" >/dev/null 2>&1 &
fi

# --- Discord (webhook; "content" field) -------------------------------------
if [ -n "${DISCORD_WEBHOOK_URL:-}" ] && command -v jq >/dev/null 2>&1; then
  content="$demoji **${title}** — ${message} \`${target}\`${suffix}"
  jq -nc --arg c "$content" '{content:$c}' \
    | curl -fsS --max-time 6 -H 'Content-type: application/json' --data @- \
        "$DISCORD_WEBHOOK_URL" >/dev/null 2>&1 &
fi

exit 0
