#!/usr/bin/env bash
# Live agent tally for the tmux status bar. Counts PANES by their @cc_status
# (set per-pane by claude/hooks/cc-status.sh) — agents often run as split panes
# in one window, so counting windows undercounts. Prints e.g. "◆1 ▸2 ✓1" —
# waiting first, so a blocked agent is the first thing you see. Empty when idle.
working=0 waiting=0 done=0
while IFS= read -r s; do
  case "$s" in
    working) working=$((working + 1)) ;;
    waiting) waiting=$((waiting + 1)) ;;
    done)    done=$((done + 1)) ;;
  esac
done < <(tmux list-panes -a -F '#{@cc_status}' 2>/dev/null)

# Single-width glyphs (◆ waiting / ▸ working / ✓ done) — same as the window
# tabs; emoji width-counts wrong in tmux status segments. Color carries state.
out=""
(( waiting )) && out+="#[fg=#e0af68,bold]◆${waiting}#[default] "
(( working )) && out+="#[fg=#7dcfff]▸${working}#[default] "
(( done ))    && out+="#[fg=#9ece6a]✓${done}#[default] "
printf '%s' "$out"
