# Ghostty config. Hot-reload in-app with cmd+r (bound below) or cmd+shift+,
# Validate after edits:  ghostty +validate-config
# Full reference: https://ghostty.org/docs/config/reference
# NOTE: never put a `# comment` after a value on the same line — Ghostty parses
# the comment text as part of the value and errors. Comments go on their own line.

# --- Theme (Tokyo Night) -----------------------------------------------------
# Use the bundled, maintained "TokyoNight Night" theme (palette/fg/cursor/
# selection all inherited — identical to the old hand-rolled block). No space
# is a typo: the catalog name is "TokyoNight Night".
theme = TokyoNight Night
# Override just the background for a true-black look (upstream theme is #1a1b26).
# Comment this out for the standard Tokyo Night navy-black background.
background = 16161e

# --- Font --------------------------------------------------------------------
font-family = JetBrainsMono Nerd Font
font-size = 14
# Ligatures: contextual alternates + standard ligatures.
font-feature = +calt
font-feature = +liga
# Slightly heavier stroke on macOS for crisper text on Retina/P3 displays.
font-thicken = true

# --- Window chrome -----------------------------------------------------------
window-padding-x = 12
window-padding-y = 12
# Keep opposite-side padding even as the grid resizes.
window-padding-balance = true
# Extend the background color into the padding instead of leaving a gap.
window-padding-color = background
# Slight translucency so the blur below is visible. 1.0 = fully opaque.
background-opacity = 0.97
# Native macOS background blur behind the translucent window.
background-blur = 20
# Dim splits that don't have focus so the active pane stands out.
unfocused-split-opacity = 0.85
# Wider-gamut rendering on Apple Silicon P3 displays.
window-colorspace = display-p3

# --- macOS-specific ----------------------------------------------------------
# Chrome-less: hide the native titlebar so tmux's top status bar IS the window's
# top edge (no redundant macOS title strip above it). Traffic-light buttons show
# on hover top-left. Ghostty tabs are unused here since tmux owns multiplexing.
macos-titlebar-style = hidden
# Treat right Option as Alt so meta keybinds work in the shell/editor.
macos-option-as-alt = true
# Restore window layout on relaunch.
window-save-state = always
# Don't prompt when closing a pane/window.
confirm-close-surface = false
# Quit Ghostty entirely when the last window closes.
# Stay resident in the background after the last window closes, so the global
# quick-terminal hotkey works anytime from any app (Quake/iTrm-style dropdown).
quit-after-last-window-closed = false
# Notify on new stable releases without auto-installing them.
auto-update = check
auto-update-channel = stable

# --- Cursor ------------------------------------------------------------------
cursor-style = block
cursor-style-blink = false
# Subtle cursor smear/trail (sahaj-b/ghostty-cursor-shaders). Trail color is
# sampled from the cursor so it follows the theme; 0.09s so it reads as motion,
# not a gimmick. `animation = always` keeps it smooth while the screen is idle.
custom-shader = shaders/cursor_tail.glsl
custom-shader-animation = always

# --- Shell integration -------------------------------------------------------
# Auto-detect zsh/bash/fish and inject integration.
shell-integration = detect
# Cursor shape per mode, sudo passthrough, window-title updates.
shell-integration-features = cursor,sudo,title

# --- Clipboard / mouse -------------------------------------------------------
copy-on-select = clipboard
mouse-hide-while-typing = true
clipboard-trim-trailing-spaces = true
# Confirm before pasting multi-line text (guards against paste-injection).
clipboard-paste-protection = true
# Cmd+click opens URLs in the default browser.
link-url = true

# --- Scrollback --------------------------------------------------------------
scrollback-limit = 100000

# --- Quick terminal (global dropdown) ----------------------------------------
# Slides down from the top of the screen under the mouse. First use of a
# global: bind needs Ghostty granted Accessibility permission in System Settings.
quick-terminal-position = top
quick-terminal-screen = mouse
quick-terminal-autohide = true

# --- Keybinds (this block doubles as a cheatsheet — see `ghostty-keys`) -------
# Splits
# cmd+d : split right
keybind = cmd+d=new_split:right
# cmd+shift+d : split down
keybind = cmd+shift+d=new_split:down
# cmd+alt+arrows : move focus between splits
keybind = cmd+alt+left=goto_split:left
keybind = cmd+alt+right=goto_split:right
keybind = cmd+alt+up=goto_split:up
keybind = cmd+alt+down=goto_split:down
# cmd+shift+enter : maximize / restore the focused split
keybind = cmd+shift+enter=toggle_split_zoom
# Font size: cmd+= bigger, cmd+- smaller, cmd+0 reset
keybind = super+equal=increase_font_size:1
keybind = super+minus=decrease_font_size:1
keybind = super+zero=reset_font_size
# cmd+r : hot-reload this config
keybind = cmd+r=reload_config
# cmd+k : clear screen + scrollback
keybind = cmd+k=clear_screen
# ctrl+grave (Ctrl+`) : toggle the global dropdown quick terminal from ANY app.
# Ctrl+` (not Cmd+`) because macOS uses Cmd+` to cycle app windows — that's why
# Cmd+` was opening a new window instead of the dropdown.
keybind = global:ctrl+grave_accent=toggle_quick_terminal
