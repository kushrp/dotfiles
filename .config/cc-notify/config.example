# cc-notify config — copy to ~/.config/cc-notify/config and fill in. NOT tracked.
# Slack: create an Incoming Webhook (api.slack.com/messaging/webhooks), paste URL.
SLACK_WEBHOOK_URL=""
# Discord: Channel → Edit → Integrations → Webhooks → New Webhook → Copy URL.
DISCORD_WEBHOOK_URL=""
# Which states go to Slack/Discord (space-separated). Desktop always gets all.
CC_NOTIFY_REMOTE_STATES="waiting"
CC_NOTIFY_DESKTOP=1
CC_NOTIFY_THROTTLE=45
