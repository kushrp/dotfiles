# travel-hacker is a vendored plugin loaded via `claude --plugin-dir`; ignore its
# runtime state so it never dirties the dotfiles repo.
travel-hacker/.in_use/
travel-hacker/.orphaned_at
travel-hacker/**/*.log

# Refreshable datasets (3.8M) — regenerated by travel-hacker/scripts/refresh-*.py.
# Kept out of git history; populate on a new machine with those scripts.
travel-hacker/data/
